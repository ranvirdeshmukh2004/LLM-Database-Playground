# ═══════════════════════════════════════════════════════════════
# MVP AI Agent Platform — Environment Variables
# Run: bash scripts/generate_keys.sh > .env
# ═══════════════════════════════════════════════════════════════

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_PASSWORD=your-strong-password-here
POSTGRES_HOST=supabase-db
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres

# ── JWT / Supabase Auth ─────────────────────────────────────
JWT_SECRET=your-64-char-jwt-secret-here
ANON_KEY=your-anon-jwt-here
SERVICE_ROLE_KEY=your-service-role-jwt-here

# ── Supabase URLs ───────────────────────────────────────────
SUPABASE_URL=http://localhost:8000
API_EXTERNAL_URL=http://localhost:8000
SUPABASE_PUBLIC_URL=http://localhost:8000

# ── Supabase Studio ────────────────────────────────────────
STUDIO_PORT=3001
STUDIO_DEFAULT_ORGANIZATION=AI Platform
STUDIO_DEFAULT_PROJECT=MVP AI Agent Platform

# ── Supabase Auth (GoTrue) ─────────────────────────────────
GOTRUE_SITE_URL=http://localhost:7860
GOTRUE_URI_ALLOW_LIST=
GOTRUE_DISABLE_SIGNUP=false
GOTRUE_EXTERNAL_EMAIL_ENABLED=true
GOTRUE_MAILER_AUTOCONFIRM=true
GOTRUE_SMS_AUTOCONFIRM=true

# ── App Secrets ─────────────────────────────────────────────
ENCRYPTION_KEY=your-fernet-encryption-key
APP_SECRET_KEY=your-app-secret-key

# ── External LLM Providers (optional system-level keys) ────
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENAI_API_KEY=

# ── App Config ──────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=7860
LOG_LEVEL=info
ENVIRONMENT=development
